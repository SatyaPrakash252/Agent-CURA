# ============================================================
# Project Cura — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
# ============================================================

# --- Groq (LLM Provider) ---
GROQ_API_KEY=gsk_your_groq_api_key_here

# --- Supabase (Database) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# --- Deepgram (Cloud Speech-to-Text - Optional but Recommended) ---
# Get a free key at https://console.deepgram.com
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# --- Whisper (Local STT Fallback) ---
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# --- Docker ---
COMPOSE_PROJECT_NAME=project-cura

# --- Auth (JWT) ---
JWT_SECRET_KEY=change-this-to-a-random-64-char-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=480

# --- Default Admin Credentials (first-run only) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-immediately

# --- CORS (comma-separated allowed origins for cloud deployment) ---
# For local development, leave unset (defaults to localhost:3000)
# For cloud deployment, set to your frontend URL:
# CORS_ORIGINS=https://project-cura-frontend.onrender.com,http://localhost:3000

# --- Frontend API URL (for cloud deployment) ---
# Set this to your deployed backend URL when deploying to cloud:
# NEXT_PUBLIC_API_BASE_URL=https://project-cura-backend.onrender.com
